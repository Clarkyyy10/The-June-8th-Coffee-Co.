// ============================================================
// The June 9th Coffee Co. — Prisma Schema (PostgreSQL)
// Full data model for the Coffee Shop Management System
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------- Enums ----------------------

enum Role {
  OWNER
  MANAGER
  CASHIER
  BARISTA
  KITCHEN
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
  OUT_OF_STOCK
}

enum Temperature {
  HOT
  ICED
  BOTH
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
  CANCELLED
  REFUNDED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum PaymentMethod {
  CASH
  GCASH
  MAYA
  CREDIT_CARD
  DEBIT_CARD
  SPLIT
}

enum PaymentStatus {
  PAID
  UNPAID
  PARTIAL
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum StockMovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  WASTE
  RETURN
}

// ---------------------- Auth / Users ----------------------

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  role          Role      @default(CASHIER)
  phone         String?
  active        Boolean   @default(true)

  accounts     Account[]
  sessions     Session[]
  orders       Order[]
  activityLogs ActivityLog[]
  shifts       Shift[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------- Catalog ----------------------

model Category {
  id          String        @id @default(cuid())
  name        String        @unique
  slug        String        @unique
  description String?
  icon        String?
  color       String?
  sortOrder   Int           @default(0)
  active      Boolean       @default(true)
  products    Product[]
  subcategories Subcategory[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Subcategory {
  id         String    @id @default(cuid())
  name       String
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products   Product[]
}

model Product {
  id              String        @id @default(cuid())
  name            String
  slug            String        @unique
  sku             String        @unique
  barcode         String?
  description     String?
  ingredients     String?
  nutrition       Json?
  servingSize     String?
  image           String?
  images          String[]      @default([])

  categoryId      String
  category        Category      @relation(fields: [categoryId], references: [id])
  subcategoryId   String?
  subcategory     Subcategory?  @relation(fields: [subcategoryId], references: [id])

  price           Decimal       @db.Decimal(10, 2)
  cost            Decimal       @db.Decimal(10, 2) @default(0)
  prepTime        Int?          // minutes
  temperature     Temperature   @default(BOTH)

  sizes           Json?         // [{ name, priceDelta }]
  addons          Json?         // [{ name, price }]
  milkOptions     String[]      @default([])
  sugarLevels     String[]      @default([])
  iceLevels       String[]      @default([])

  status          ProductStatus @default(ACTIVE)
  featured        Boolean       @default(false)
  bestSeller      Boolean       @default(false)
  recommended     Boolean       @default(false)
  seasonal        Boolean       @default(false)
  availableFrom   DateTime?
  availableTo     DateTime?

  stock           Int           @default(0)
  lowStockAlert   Int           @default(10)
  sortOrder       Int           @default(0)

  supplierId      String?
  supplier        Supplier?     @relation(fields: [supplierId], references: [id])

  notes           String?
  orderItems      OrderItem[]
  recipe          RecipeItem[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([categoryId])
  @@index([status])
}

// ---------------------- Inventory ----------------------

model Supplier {
  id            String          @id @default(cuid())
  name          String
  contactName   String?
  email         String?
  phone         String?
  address       String?
  products      Product[]
  ingredients   Ingredient[]
  createdAt     DateTime        @default(now())
}

model Ingredient {
  id            String            @id @default(cuid())
  name          String
  unit          String            // g, ml, pcs
  currentStock  Decimal           @db.Decimal(12, 2) @default(0)
  minStock      Decimal           @db.Decimal(12, 2) @default(0)
  maxStock      Decimal           @db.Decimal(12, 2) @default(0)
  purchaseCost  Decimal           @db.Decimal(10, 2) @default(0)
  expirationDate DateTime?
  restockReminder Boolean         @default(true)

  supplierId    String?
  supplier      Supplier?         @relation(fields: [supplierId], references: [id])

  recipeItems   RecipeItem[]
  movements     StockMovement[]

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model RecipeItem {
  id           String     @id @default(cuid())
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Decimal    @db.Decimal(12, 2)

  @@unique([productId, ingredientId])
}

model StockMovement {
  id           String            @id @default(cuid())
  ingredientId String
  ingredient   Ingredient        @relation(fields: [ingredientId], references: [id])
  type         StockMovementType
  quantity     Decimal           @db.Decimal(12, 2)
  note         String?
  createdAt    DateTime          @default(now())

  @@index([ingredientId])
}

// ---------------------- Orders / Sales ----------------------

model Order {
  id            String        @id @default(cuid())
  number        String        @unique
  status        OrderStatus   @default(PENDING)
  type          OrderType     @default(DINE_IN)

  customerId    String?
  customer      Customer?     @relation(fields: [customerId], references: [id])
  cashierId     String?
  cashier       User?         @relation(fields: [cashierId], references: [id])

  items         OrderItem[]

  subtotal      Decimal       @db.Decimal(10, 2)
  discountId    String?
  discount      Discount?     @relation(fields: [discountId], references: [id])
  discountTotal Decimal       @db.Decimal(10, 2) @default(0)
  taxTotal      Decimal       @db.Decimal(10, 2) @default(0)
  tipTotal      Decimal       @db.Decimal(10, 2) @default(0)
  total         Decimal       @db.Decimal(10, 2)

  paymentMethod PaymentMethod @default(CASH)
  paymentStatus PaymentStatus @default(PAID)
  amountPaid    Decimal       @db.Decimal(10, 2) @default(0)
  notes         String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  completedAt   DateTime?

  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  name         String
  quantity     Int      @default(1)
  unitPrice    Decimal  @db.Decimal(10, 2)
  size         String?
  temperature  String?
  sugarLevel   String?
  iceLevel     String?
  milkOption   String?
  addons       Json?
  notes        String?
  lineTotal    Decimal  @db.Decimal(10, 2)
}

// ---------------------- Customers ----------------------

model Customer {
  id            String   @id @default(cuid())
  name          String
  email         String?  @unique
  phone         String?
  birthday      DateTime?
  address       String?
  favoriteDrink String?
  loyaltyPoints Int      @default(0)
  lifetimeSpend Decimal  @db.Decimal(12, 2) @default(0)
  visitCount    Int      @default(0)
  vip           Boolean  @default(false)
  notes         String?
  orders        Order[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ---------------------- Marketing ----------------------

model Discount {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String
  type        DiscountType @default(PERCENTAGE)
  value       Decimal      @db.Decimal(10, 2)
  minSpend    Decimal?     @db.Decimal(10, 2)
  active      Boolean      @default(true)
  usageLimit  Int?
  usageCount  Int          @default(0)
  startsAt    DateTime?
  endsAt      DateTime?
  orders      Order[]
  createdAt   DateTime     @default(now())
}

// ---------------------- Staff / Ops ----------------------

model Shift {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  clockIn   DateTime  @default(now())
  clockOut  DateTime?
  note      String?
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String?
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ---------------------- Settings ----------------------

model Setting {
  id            String  @id @default(cuid())
  businessName  String  @default("The June 9th Coffee Co.")
  logo          String?
  banner        String?
  address       String?
  phone         String?
  email         String?
  hours         Json?
  taxRate       Decimal @db.Decimal(5, 2) @default(12)
  currency      String  @default("PHP")
  receiptFooter String?
  theme         String  @default("system")
  accentColor   String  @default("caramel")
}
